# ===========================================
# MyKIZ Platform - Environment Configuration
# ===========================================
# Copy this file to .env and adjust values as needed.
# cp .env.example .env

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mykiz
DB_USER=mykiz
DB_PASSWORD=mykiz_secret

# -------------------------------------------
# MinIO (Object Storage)
# -------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=mykiz_minio
MINIO_SECRET_KEY=mykiz_minio_secret
MINIO_BUCKET_NAME=mykiz-uploads
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=change-me-to-a-secure-random-string
